# Environment Variables Configuration
# Copy this file to .env and configure the values for your environment

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/airemixer

# Server Configuration
PORT=5000
HOST=localhost
NODE_ENV=development

# Security Configuration
MAX_FILE_SIZE=15728640
MAX_PROCESSING_TIME=600000
MAX_AUDIO_FILE_SIZE=524288000

# Python Configuration
PYTHON_PATH=python

# Audio Processing Limits
MAX_CONCURRENT_PROCESSES=3
CLEANUP_INTERVAL=3600000

# Temporary Directory Security
TEMP_DIR_PREFIX=airemixer_
SECURE_TEMP_PERMISSIONS=700

# Development Settings (remove in production)
DEBUG_LOGGING=true

# Audit Logging Configuration
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_TO_FILE=true
AUDIT_LOG_TO_CONSOLE=true
AUDIT_LOG_FILE=./logs/audit.log
AUDIT_INCLUDE_REQUEST_DETAILS=true
AUDIT_LOG_RETENTION_DAYS=90

# Security Headers (for production)
# ENABLE_SECURITY_HEADERS=true
# CORS_ORIGIN=https://your-domain.com
# SESSION_SECRET=your-super-secret-session-key
